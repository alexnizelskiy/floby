# ── floby: переменные окружения ──
# Скопируйте в .env.local и заполните. Без них проект работает в dev-режиме:
# встроенный Postgres (PGlite), SMS-код печатается на экран, оплата симулируется.

# База данных (прод). Если пусто — используется встроенный PGlite (.pglite/).
# Пример (Neon/Supabase/свой Postgres):
# DATABASE_URL=postgres://user:password@host:5432/floby

# SMS (SMSC.ru). Без них код показывается в модалке (dev).
# SMSC_LOGIN=ваш_логин
# SMSC_PASSWORD=ваш_пароль
# SMSC_SENDER=          # имя отправителя (если согласовано в SMSC)

# Оплата (ЮKassa). Без них card-оплата симулируется (test). Тестовые ключи
# берутся бесплатно в личном кабинете ЮKassa (для самозанятых доступно).
# YOOKASSA_SHOP_ID=ваш_shopId
# YOOKASSA_SECRET_KEY=ваш_секретный_ключ
# Webhook в настройках ЮKassa указать на: https://ВАШ_ДОМЕН/api/payments/webhook
